rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Default rule: reject all access
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Public read access to hero and gallery images, authenticated write
    match /hero/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /faculty/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
